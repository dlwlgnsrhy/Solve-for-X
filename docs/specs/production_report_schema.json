{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductionReport",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agent_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "completed",
        "failed",
        "in_progress"
      ]
    },
    "summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "file",
              "directory",
              "image",
              "log"
            ]
          }
        }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "task_id",
    "timestamp",
    "status"
  ]
}