# 환경변수 파일 (모든 변형)
.env
.env.*
*.env

# 가상환경
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# 로그
*.log
*.err
*.out

# 인증서 및 키
*.pem
*.key
*.p12
*.pfx
