# Fastlane configuration for Origin
# Run `bundle install` then `bundle exec fastlane <lane>`

default_platform(:android)

# ═════════════════════════════════════────────══════════════════════
#  Android — Full deployment pipeline
# ═══════════════════════════════════════════════════════════
platform :android do

  # ─── Test ───────────────────────────────────────────────
  desc "Run all Flutter tests"
  lane :test do
    sh("flutter", "test")
  end

  # ─── Debug Build ────────────────────────────────────────
  desc "Build debug APK for development"
  lane :debug_android do
    gradle(task: 'assembleDebug', build_type: 'Debug')
    sh("cp", "app/build/outputs/apk/debug/app-debug.apk", "/Users/shared/Origin-debug.apk")
  end

  # ─── Internal Testing ───────────────────────────────────
  desc "Build and deploy to Google Play Internal Testing"
  lane :internal do
    gradle(task: 'bundle', build_type: 'Release', profile: 'release', print_command: false)

    upload_to_play_store(
      aab_path: 'app/build/outputs/bundle/release/app-release.aab',
      track: 'internal',
      skip_upload_metadata: false,
      json_key_file: '.env/google-play-service-account.json',
      package_name: 'com.sfx.origin',
      contact_email: 'dev@soluni.com'
    )
  end

  # ─── Closed (Beta) Testing ──────────────────────────────
  desc "Build and deploy to Google Play Closed Testing"
  lane :closed do
    gradle(task: 'bundle', build_type: 'Release', profile: 'release')

    upload_to_play_store(
      aab_path: 'app/build/outputs/bundle/release/app-release.aab',
      track: 'beta',
      skip_upload_metadata: false,
      json_key_file: '.env/google-play-service-account.json',
      package_name: 'com.sfx.origin',
      contact_email: 'dev@soluni.com'
    )
  end

  # ─── Production ─────────────────────────────────────────
  desc "Build and deploy to Google Play Production"
  lane :production do
    gradle(task: 'bundle', build_type: 'Release', profile: 'release')

    upload_to_play_store(
      aab_path: 'app/build/outputs/bundle/release/app-release.aab',
      track: 'production',
      skip_upload_metadata: false,
      json_key_file: '.env/google-play-service-account.json',
      package_name: 'com.sfx.origin',
      contact_email: 'dev@soluni.com',
      rollout: '0.1'
    )

    slack(
      message: "🚀 Origin Android released to Production! Build: #{version_code}",
      success: true,
      channel: "#dev"
    )
  end

end
