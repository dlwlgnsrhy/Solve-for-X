# Fastlane configuration for Legacy Vault
# Run `bundle install` then `bundle exec fastlane testflight`
default_platform(:ios)

# ─── Shared Scheme Detection ──────────────────────────
def detect_scheme(project_path)
  schemes = Dir.glob("#{project_path}/**/*.xcscheme")
  return nil if schemes.empty?
  # First non-internal scheme
  schemes.find { |s| s !~ /Internal/ }
end

# ─── Build Settings ───────────────────────────────────
def legacy_vault_build_settings
  {
    configuration: "Release",
    scheme: "LegacyVaultApp",
    destination: "generic/platform=iOS Simulator",
    skip_testable_scheme_detection: true,
    skip_archive: false,
    skip_build: false,
    export_method: "app-store",
    export_options: {
      signstyle: "manual",
      ProvisionsMultipleProfiles: false,
    },
  }
end

# ─── Actions ──────────────────────────────────────────
platform :ios do
  
  desc "Verify project builds (release, no tests)"
  lane :verify_build do
    echo "═══ Legacy Vault — Verify Build ═══"
    
    # Run privacy audit first
    sh("bash", "apps/legacy_vault/PrivacyAudit.sh")
    
    # Ensure zero compile errors
    result = sh("xcrun", "swiftc", "-target", "arm64-apple-ios17.0-simulator", 
                "-sdk", `xcrun --sdk iphonesimulator --show-sdk-path`.strip,
                "apps/legacy_vault/legacy_vault/**/*.swift",
                "-emit-executable",
                "-o", "/dev/null",
                "-suppress-warnings"
                ).strip rescue "UNKNOWN"
    
    puts result
    puts "✅ Verify build complete"
  end
  
  desc "Build for TestFlight distribution"
  lane :testflight do
    # 1. Privacy audit
    sh("bash", "apps/legacy_vault/PrivacyAudit.sh")
    
    # 2. Build release scheme
    build_app(
      skip_analyze: true,
      skip_archive: false,
      skip_build: false,
      export_method: "app-store",
    )
    
    # 3. Upload to TestFlight
    upload_to_testflight(skip_waiting_for_build_processing: true)
    
    puts "✅ Uploaded to TestFlight"
  end
  
  desc "Run all tests"
  lane :test do
    # Unit tests
    run_tests(
      scheme: "LegacyVaultTests",
      only: "Unit",
      devices: ["iPhone 15"],
    )
    
    # Integration tests
    run_tests(
      scheme: "LegacyVaultIntegration",
      only: "Integration",
      devices: ["iPhone 15"],
    )
  end
  
  desc "Full CI pipeline: audit → build → testflight"
  lane :ci do
    verify_build
    test
    testflight
  end

  desc "🔍 Privacy audit — no network imports"
  lane :privacy_audit do
    sh("bash", "#{fastlane_folder}/PrivacyAudit.sh")
  end

  desc "🧹 Lint — SwiftLint"
  lane :lint do
    sh("bash", "-c", "command -v swiftlint >/dev/null 2>&1 && swiftlint lint --strict --quiet || echo 'SwiftLint not installed, skipping'")
  end

  desc "🧪 Run Unit Tests"
  lane :unit_tests do
    run_tests(
      scheme: "LegacyVaultApp",
      devices: ["iPhone 16"],
      skip_analyze: true,
      skip_testable_scheme_detection: true
    )
  end

  desc "🧪 Run Integration Tests"
  lane :integration_tests do
    run_tests(
      scheme: "LegacyVaultIntegration",
      devices: ["iPhone 16"],
      skip_analyze: true,
      skip_testable_scheme_detection: true
    )
  end

  desc "🏗️ Build IPA for App Store"
  lane :build_ipa do
    match(
      app_identifier: ["com.sfx.legacyvault"],
      type: "appstore",
      readonly: true,
      git_url: "https://github.com/soluni/legacy-vault-certs.git",
      shallow: true
    )
    build_app(
      scheme: "LegacyVaultApp",
      configuration: "Release",
      export_method: "app-store",
      skip_analyze: true,
      skip_testable_scheme_detection: true,
      export_options: { signStyle: "manual" }
    )
    cp("build/Release-iphoneos/LegacyVaultApp.ipa", "build/output/LegacyVaultApp.ipa")
  end

  desc "📤 Upload to TestFlight"
  lane :upload_testflight do
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      ipa: "build/output/LegacyVaultApp.ipa"
    )
    slack(
      message: "✅ LegacyVault iOS uploaded to TestFlight! Build #{lane_context[SharedValues::BUILD_NUMBER]}",
      success: true
    )
  end

  desc "🛣️ Full beta pipeline"
  lane :beta do
    privacy_audit
    lint
    unit_tests
    integration_tests
    build_ipa
    upload_testflight
  end

  desc "🚀 Production — submit to App Store Connect"
  lane :production do
    beta
    # submit_to_app_store_connect
  end

  desc "📢 Send Slack notification"
  lane :slack_notify do |options|
    slack(
      message: options[:message] || "LegacyVault build #{lane_context[SharedValues::BUILD_NUMBER]} processed",
      success: options.fetch(:success, true)
    )
  end
end
