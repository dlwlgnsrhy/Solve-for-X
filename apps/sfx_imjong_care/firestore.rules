rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /wills/{willId} {
      // Allow read access if the user is the owner, or if the will is explicitly marked as public
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || 
                     (resource.data.isPublic == true);
      
      // Allow creation if the user is authenticated, binds their own uid, and starts with 0 likes
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid &&
                     request.resource.data.likes == 0;
      
      // Allow updates to 'likes' count by anyone, but changes to actual content only by owner
      // Strictly enforce that 'likes' can only be incremented by exactly +1 to prevent manipulation
      allow update: if (request.auth != null && resource.data.userId == request.auth.uid) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
                      request.resource.data.likes == resource.data.likes + 1);
      
      // Allow deletion only by the owner
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
