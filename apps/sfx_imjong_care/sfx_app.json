{
  "id": "sfx_imjong_care",
  "name": "SFX Imjong Care",
  "version": "1.0.0",
  "tech_stack": "flutter_web",
  "workspace_path": "apps/sfx_imjong_care",
  "commands": {
    "bootstrap": "flutter pub get",
    "build": "flutter build web --release",
    "test": "flutter test",
    "dev_server": {
      "command": "flutter run -d web-server --web-port={port}",
      "url": "http://localhost:{port}",
      "health_check_timeout": 30
    }
  },
  "visual_qa": {
    "enabled": true,
    "threshold_percent": 1.5,
    "baseline_name": "sfx_real_support_desk.png",
    "routes": [
      {
        "path": "/",
        "output_filename": "sfx_imjong_care_home.png",
        "delay_ms": 3000
      }
    ]
  },
  "dependency_files": ["pubspec.yaml"]
}
